<launch>
  <arg name="input_topic" default="/ur5e/joint_command" />
  <arg name="output_topic" default="/joint_states" />
  <arg name="rl_action_topic" default="/rl_action" />
  <arg name="action_mode" default="position" />
  <arg name="send_to_controller" default="false" />
  <arg name="use_rviz" default="true" />

  <param name="robot_description"
         textfile="$(find ur5e_rl_control)/asset/ur_e_description/urdf/ur5e.urdf" />

  <node pkg="ur5e_rl_control"
        type="joint_state_visualizer.py"
        name="ur5e_joint_state_bridge"
        unless="$(arg send_to_controller)"
        output="screen">
    <rosparam command="load" file="$(find ur5e_rl_control)/config/cfg.yaml" />
    <param name="input_topic" value="$(arg input_topic)" />
    <param name="output_topic" value="$(arg output_topic)" />
  </node>

  <node pkg="ur5e_rl_control"
        type="ur5e_execution_node"
        name="ur5e_execution_node"
        output="screen">
    <rosparam command="load" file="$(find ur5e_rl_control)/config/cfg.yaml" />
    <param name="rl_action_topic" value="$(arg rl_action_topic)" />
    <param name="visualization_topic" value="$(arg input_topic)" />
    <param name="joint_state_topic" value="$(arg output_topic)" />
    <param name="action_mode" value="$(arg action_mode)" />
    <param name="send_to_controller" value="$(arg send_to_controller)" />
  </node>

  <node pkg="robot_state_publisher"
        type="robot_state_publisher"
        name="robot_state_publisher"
        output="screen">
    <remap from="joint_states" to="$(arg output_topic)" />
  </node>

  <node if="$(arg use_rviz)"
        pkg="rviz"
        type="rviz"
        name="rviz"
        args="-d $(find ur5e_rl_control)/rviz/ur5e.rviz"
        output="screen" />
</launch>
